APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# MyRadl / Nextbike
GBFS_NETWORK_ID=ml
# Set true for strict docked systems; keep false for MyRadl parking-zone behavior.
ENFORCE_DESTINATION_DOCKS=false

# OpenRouteService (required for /plan routing; geocoding uses Photon)
ORS_API_KEY=your_ors_api_key_here
ORS_BASE_URL=https://api.heigit.org/openrouteservice

# Photon geocoding (search box; no API key)
PHOTON_BASE_URL=https://photon.komoot.io
GEOCODE_LANG=de
GEOCODE_BBOX=11.3,48.0,11.8,48.3

# Refresh cadence
STATUS_REFRESH_SECONDS=60
STATIC_REFRESH_SECONDS=21600

# Feedback -> GitHub issues
GITHUB_FEEDBACK_TOKEN=
FEEDBACK_REPO=Akshat125/myradl-route-planner
