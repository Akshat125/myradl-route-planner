APP_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# MyRadl / Nextbike
GBFS_NETWORK_ID=ml
# Set true for strict docked systems; keep false for MyRadl parking-zone behavior.
ENFORCE_DESTINATION_DOCKS=false

# OpenRouteService (required for /plan)
ORS_API_KEY=your_ors_api_key_here
ORS_BASE_URL=https://api.heigit.org/openrouteservice
ORS_GEOCODE_URL=https://api.heigit.org/pelias/v1

# Refresh cadence
STATUS_REFRESH_SECONDS=60
STATIC_REFRESH_SECONDS=21600
